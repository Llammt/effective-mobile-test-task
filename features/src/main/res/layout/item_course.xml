<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="#24252A"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:cardPreventCornerOverlap="false">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/ivCourseCover"
            android:layout_width="match_parent"
            android:layout_height="114dp"
            android:scaleType="centerCrop"
            android:background="#32333A"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:src="@tools:sample/backgrounds/scenic" />

        <FrameLayout
            android:id="@+id/btnFavoriteContainer"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginTop="8dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_glass_pill"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintTop_toTopOf="@id/ivCourseCover"
            app:layout_constraintEnd_toEndOf="@id/ivCourseCover">

            <ImageView
                android:id="@+id/ivFavorite"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="center"
                android:src="@android:drawable/btn_star_big_off"
                app:tint="#F2F2F3" />
        </FrameLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="22dp"
            android:orientation="horizontal"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="8dp"
            app:layout_constraintBottom_toBottomOf="@id/ivCourseCover"
            app:layout_constraintStart_toStartOf="@id/ivCourseCover">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="6dp"
                android:background="@drawable/bg_glass_pill">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@android:drawable/btn_star_big_on"
                    app:tint="#12B956" />

                <TextView
                    android:id="@+id/tvRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text=" "
                    android:textColor="#F2F2F3"
                    android:textSize="12sp"
                    android:fontFamily="@font/roboto" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginStart="4dp"
                android:paddingHorizontal="6dp"
                android:background="@drawable/bg_glass_pill">

                <TextView
                    android:id="@+id/tvPublishDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" "
                    android:textColor="#F2F2F3"
                    android:textSize="12sp"
                    android:fontFamily="@font/roboto" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/tvCourseTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginHorizontal="16dp"
            android:textColor="#F2F2F3"
            android:textSize="16sp"
            android:fontFamily="@font/roboto"
            android:fontWeight="500"
            app:layout_constraintTop_toBottomOf="@id/ivCourseCover"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text=" " />

        <TextView
            android:id="@+id/tvCourseDescription"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_marginTop="12dp"
            android:textColor="#F2F2F3"
            android:alpha="0.7"
            android:textSize="12sp"
            android:fontFamily="@font/roboto"
            android:maxLines="2"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/tvCourseTitle"
            app:layout_constraintStart_toStartOf="@id/tvCourseTitle"
            app:layout_constraintEnd_toEndOf="@id/tvCourseTitle"
            tools:text=" " />

        <TextView
            android:id="@+id/tvCoursePrice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:textColor="#F2F2F3"
            android:textSize="16sp"
            android:fontFamily="@font/roboto"
            android:fontWeight="500"
            app:layout_constraintTop_toBottomOf="@id/tvCourseDescription"
            app:layout_constraintStart_toStartOf="@id/tvCourseDescription"
            tools:text=" " />

        <LinearLayout
            android:id="@+id/btnMore"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:clickable="true"
            android:focusable="true"
            app:layout_constraintBottom_toBottomOf="@id/tvCoursePrice"
            app:layout_constraintTop_toTopOf="@id/tvCoursePrice"
            app:layout_constraintEnd_toEndOf="@id/tvCourseDescription">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=" "
                android:textColor="#12B956"
                android:textSize="12sp"
                android:fontFamily="@font/roboto"
                android:fontWeight="600"
                android:letterSpacing="0.03" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/ic_arrow_right"
                app:tint="#12B956" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>